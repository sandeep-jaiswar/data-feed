# NSE Data ETL Environment Configuration
# Copy this file to .env and update values for your environment

# Application Settings
APP_NAME="NSE Data ETL"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG="true"

# Security Settings (REQUIRED)
SECRET_KEY="your-secret-key-here-change-in-production"

# API Settings
API_HOST="0.0.0.0"
API_PORT="8080"
API_WORKERS="1"

# Logging Settings
LOG_LEVEL="DEBUG"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT="text"  # text, json
LOG_FILE=""  # Leave empty for console logging

# Database Settings - ClickHouse
CLICKHOUSE_HOST="localhost"
CLICKHOUSE_PORT="9000"
CLICKHOUSE_DATABASE="nse_data"
CLICKHOUSE_USER="nse_user"
CLICKHOUSE_PASSWORD="your-clickhouse-password"

# Database Settings - Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_DB="0"
REDIS_PASSWORD="your-redis-password"

# Monitoring Settings
PROMETHEUS_HOST="localhost"
PROMETHEUS_PORT="9090"
METRICS_PORT="8000"
HEALTH_CHECK_INTERVAL="30"
ALERT_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Data Collection Settings
NSE_BASE_URL="https://www.nseindia.com"
NSE_API_TIMEOUT="30"
NSE_RATE_LIMIT="100"  # requests per minute

# WebSocket Settings
WEBSOCKET_URL="wss://your-websocket-url"
WEBSOCKET_RECONNECT_INTERVAL="5"

# Data Collection Intervals (seconds)
EQUITY_DATA_INTERVAL="1"
DERIVATIVES_DATA_INTERVAL="1"
INDICES_DATA_INTERVAL="5"

# Performance Settings
MAX_WORKERS="4"
BATCH_SIZE="1000"
QUEUE_SIZE="10000"

# Security Settings
ALLOWED_HOSTS="*"  # Comma-separated list, use specific domains in production
CORS_ORIGINS="*"   # Comma-separated list, use specific origins in production

# Docker Compose Settings (for development)
BUILD_DATE=""
VCS_REF=""
VERSION="0.1.0"

# Third-party Service Credentials
GRAFANA_USER="admin"
GRAFANA_PASSWORD="admin123"

# SSL/TLS Settings (for production)
SSL_CERT_PATH="/etc/ssl/certs/nse-etl.crt"
SSL_KEY_PATH="/etc/ssl/private/nse-etl.key"

# Backup Settings (for production)
BACKUP_ENABLED="false"
BACKUP_INTERVAL_HOURS="6"
BACKUP_RETENTION_DAYS="30"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BACKUP_BUCKET=""